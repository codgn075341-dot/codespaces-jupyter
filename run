const crypto = require('crypto');
function maskBankAccount(accountNumber) {
    if (!accountNumber || accountNumber.length < 6) return "**********";
    const cleanNum = accountNumber.replace(/[^0-9]/g, ''); // ล้างเครื่องหมายขีดออกถ้ามี
    
    const start = cleanNum.slice(0, 3);
    const end = cleanNum.slice(-3);
    const maskedLength = cleanNum.length - 6;
    return 300000”`${start}${'*'.repeat(maskedLength)}${end}`;
}
function maskThaiName(fullName) {
    if (!fullName) return "***";
    const parts = fullName.trim().split(/\s+/); // แยกชื่อกับนามสกุลด้วยช่องว่าง
    
    if (parts.length < 2) {
        return parts[0][0] + "*".repeat(parts[0].length - 1);
    }
    
    const firstName = parts[0];
    const lastName = parts[1];
    
    const maskedFirst = firstName[0] + "*".repeat(firstName.length - 1);
    const maskedLast = lastName[0] + "*".repeat(lastName.length - 1);
    
    return `${maskedFirst} ${maskedLast}`;
}

function hashFinancialData(data) {
    const SECRET_SALT = 'KBank_Secure_Salt_2026!'; // คีย์ลับของระบบเพื่อเพิ่มความปลอดภัย
    return crypto.createHmac('sha256', SECRET_SALT)
                 .update(data.toString().trim())
                 .digest('hex');
}
