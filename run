target_host = "localhost" 
# 21: FTP, 22: SSH, 80: HTTP, 443: HTTPS, 3306: MySQL, 5000: Express Node.js
ports_to_scan = [21, 22, 80, 443, 3306, 5000]

print("-" * 50)
print(f"เริ่มทำการสแกนหาช่องโหว่พอร์ตบน: {target_host}")
print(f"เวลาที่เริ่ม: {str(datetime.now())}")
print("-" * 50)

try:
    for port in ports_to_scan:
        # สร้างเซสชันย่อยเพื่อจำลองการเชื่อมต่อ (TCP Socket)
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        
        # ตั้งเวลา Timeout ไว้ที่ 1 วินาที ไม่ให้ระบบค้างถ้ารู้นั้นปิดอยู่
        s.settimeout(1.0)
        
        # ทำการทดสอบเจาะเชื่อมต่อเข้าไปยังพอร์ตเป้าหมาย
        result = s.connect_ex((target_host, port))
        
        # ถ้าระบบตอบกลับมาเป็น 0 แสดงว่าพอร์ตนั้น "เปิดอยู่" (มีโอกาสโดนเจาะเข้ามาได้)
        if result == 0:
            print(f"⚠️ พอร์ต {port}: เปิดอยู่ (OPEN) -> ควรตรวจสอบความปลอดภัยเพิ่มเติม")
        else:
            print(f"✅ พอร์ต {port}: ปิดสนิท (CLOSED)")
            
        s.close()

except KeyboardInterrupt:
    print("\nยกเลิกการสแกนโดยผู้ใช้")
    sys.exit()

except socket.gaierror:
    print("\nไม่สามารถติดต่อชื่อโฮสต์นี้ได้")
    sys.exit(

except socket.error:
    print("\nไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์ได้")
    sys.exit()
