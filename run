from pydantic import BaseModel
import sqlite3

app = FastAPI(title="Real Wallet API", description="ระบบกระเป๋าเงินใช้งานจริง รองรับฐานข้อมูล")

DB_NAME = "wallet.db"

# --- ส่วนจัดการฐานข้อมูล (Database Management) ---
def init_db():
    """สร้างตารางเก็บข้อมูลเงินในระบบ (รันครั้งแรกครั้งเดียว)"""
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS wallets (
            account_id TEXT PRIMARY KEY,
            owner_name TEXT NOT NULL,
            balance REAL DEFAULT 0.0
        )
    ''')
    conn.commit()
    conn.close()

# เรียกใช้งานเพื่อสร้างฐานข้อมูลทันทีเมื่อเปิดเซิร์ฟเวอร์
init_db()

# --- โครงสร้างข้อมูลสำหรับรับค่าผ่าน API (Data Schemas) ---
class CreateWalletRequest(BaseModel):
    account_id: str
    owner_name: str
    initial_balance: float = 0.0

class TransactionRequest(BaseModel):
    amount: float

# --- ส่วนของช่องทางเชื่อมต่อ API (API Endpoints) ---

@app.post("/wallets/create", summary="1. เปิดบัญชีกระเป๋าเงินใหม่")
def create_wallet(data: CreateWalletRequest):
    if data.initial_balance < 0:
        raise HTTPException(status_code=400, detail="ยอดเงินเริ่มต้นต้องไม่ติดลบ")
        
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    try:
        cursor.execute(
            "INSERT INTO wallets (account_id, owner_name, balance) VALUES (?, ?, ?)",
            (data.account_id, data.owner_name, data.initial_balance)
        )
        conn.commit()
        return {"status": "success", "message": f"เปิดบัญชี {data.account_id} เรียบร้อย"}
    except sqlite3.IntegrityError:
        raise HTTPException(status_code=400, detail="ID บัญชีนี้มีอยู่ในระบบแล้ว")
    finally:
        conn.close()

@app.get("/wallets/{account_id}/balance", summary="2. ตรวจสอบยอดเงินคงเหลือ")
def get_balance(account_id: str):
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    cursor.execute("SELECT owner_name, balance FROM wallets WHERE account_id = ?", (account_id,))
    row = cursor.fetchone()
    conn.close()
    
    if not row:
        raise HTTPException(status_code=404, detail="ไม่พบบัญชีนี้ในระบบ")
        
    return {"account_id": account_id, "owner_name": row[0], "balance": row[1]}

@app.post("/wallets/{account_id}/deposit", summary="3. ฝากเงินเข้าระบบ")
def deposit(account_id: str, request: TransactionRequest):
    if request.amount <= 0:
        raise HTTPException(status_code=400, detail="จำนวนเงินฝากต้องมากกว่า 0 บาท")
        
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    
    # ดึงเงินปัจจุบันมาตรวจสอบก่อนว่ามีบัญชีไหม
    cursor.execute("SELECT balance FROM wallets WHERE account_id = ?", (account_id,))
    row = cursor.fetchone()
    if not row:
        conn.close()
        raise HTTPException(status_code=404, detail="ไม่พบบัญชีนี้ในระบบ")
        
    # อัปเดตยอดเงินฝากเข้าฐานข้อมูลจริง
    new_balance = row[0] + request.amount
    cursor.execute("UPDATE wallets SET balance = ? WHERE account_id = ?", (new_balance, account_id))
    conn.commit()
    conn.close()
    
    return {"status": "success", "message": f"ฝากเงินสำเร็จ ยอดเงินใหม่คือ {new_balance:,.2f} บาท"}

@app.post("/wallets/{account_id}/withdraw", summary="4. ถอนเงินออกจากระบบ")
def withdraw(account_id: str, request: TransactionRequest):
    if request.amount <= 0:
        raise HTTPException(status_code=400, detail="จำนวนเงินถอนต้องมากกว่า 0 บาท")
        
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    
    cursor.execute("SELECT balance FROM wallets WHERE account_id = ?", (account_id,))
    row = cursor.fetchone()
    if not row:
        conn.close()
        raise HTTPException(status_code=404, detail="ไม่พบบัญชีนี้ในระบบ")
        
    current_balance = row[0]
    
    # บล็อกระบบความปลอดภัย: ป้องกันไม่ให้เงินในฐานข้อมูลติดลบเด็ดขาด
    if request.amount > current_balance:
        conn.close()
        raise HTTPException(status_code=400, detail=f"เงินไม่พอถอน (มีอยู่จริงแค่ {current_balance:,.2f} บาท)")
        
    # หักเงินออกจากฐานข้อมูลจริง
    new_balance = current_balance - request.amount
    cursor.execute("UPDATE wallets SET balance = ? WHERE account_id = ?", (new_balance, account_id))
    conn.commit()
    conn.close()
    
    return {"status": "success", "message": f"ถอนเงินสำเร็จ ยอดเงินคงเหลือคือ {new_balance:,.2f} บาท"}

