// ปรับแต่ง Content Security Policy (CSP) อนุญาตให้รันสคริปต์เฉพาะที่ปลอดภัยเท่านั้น
app.use(
  helmet.contentSecurityPolicy({
    directives: {
      defaultSrc: ["'self'"],
      scriptSrc: ["'self'", "'trusted-cdn.com'"], // อนุญาตเฉพาะสคริปต์จากโดเมนตัวเองและเว็บที่ไว้ใจ
      objectSrc: ["'none'"],
      upgradeInsecureRequests: [], // บังคับเปลี่ยน HTTP เป็น HTTPS อัตโนมัติ
    },
  })
);
const allowedOrigins = ['https://your-secure-website.com']; // ใส่ URL หน้าเว็บจริงของคุณที่นี่
app.use(cors({
  origin: function (origin, callback) {
    if (!origin || allowedOrigins.indexOf(origin) !== -1) {
      callback(null, true);
    } else {
      callback(new Error('สิทธิ์การเข้าถึงถูกปฏิเสธโดยระบบรักษาความปลอดภัย (CORS)'));
    }
  },
// Parsing ข้อมูลที่ส่งเข้ามา
app.use(express.json({ limit: '10kb' })); // จำกัดขนาด JSON ไม่เกิน 10KB ป้องกันการยิงไฟล์ขนาดใหญ่เพื่อทำลายเซิร์ฟเวอร์ (DoS)
app.use(cookieParser());

